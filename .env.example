# ─── Fee config ───────────────────────────────────────────────────────────────
TREASURY_ADDRESS=0xYourTreasuryWalletAddress
FEE_PERCENTAGE=0.003

# ─── Aggregator API keys (server-side only — NEVER expose to client) ──────────

# 0x Swap API v2 — free key at: https://dashboard.0x.org
ZRX_API_KEY=your_0x_api_key_here

# 1inch v6 — free key at: https://portal.1inch.dev
# If not set, 1inch is silently skipped (other providers still active)
ONEINCH_API_KEY=your_1inch_api_key_here

# Paraswap — no key required (free public API)
# OpenOcean — no key required (free public API)
# Odos — no key required (free public API)
# KyberSwap — no key required (free public API)

# LiFi — optional key for higher rate limits: https://li.fi/sdk
# Without a key, LiFi still works at lower rate limits
LIFI_API_KEY=

# ─── Wallet ───────────────────────────────────────────────────────────────────
# Get free project ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ─── RPC (public free endpoints) ──────────────────────────────────────────────
NEXT_PUBLIC_POLYGON_RPC=https://polygon-rpc.com
NEXT_PUBLIC_ETHEREUM_RPC=https://cloudflare-eth.com
NEXT_PUBLIC_ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_OPTIMISM_RPC=https://mainnet.optimism.io
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org

# ─── Vercel KV (add after connecting KV in Vercel dashboard) ──────────────────
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
